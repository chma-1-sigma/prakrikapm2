<Window x:Class="AgroControlClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АГРОКОНТРОЛЬ - Модуль технолога"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковое меню -->
        <Border Grid.Column="0" Background="#2C3E50">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Логотип и название (картинка слева от текста) -->
                    <Border Background="#1A252F" Height="80">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- КАРТИНКА СЛЕВА -->
                            <Image x:Name="LogoImage" Width="40" Height="40" Margin="0,0,10,0" Stretch="Uniform"/>
                            <TextBlock Text="АГРОКОНТРОЛЬ" 
                                       FontSize="16" FontWeight="Bold" 
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Информация о пользователе -->
                    <Border Background="#3D566E" Margin="0,10,0,10" Padding="15,10">
                        <StackPanel>
                            <TextBlock x:Name="txtUserName" Text="Иванов Иван Петрович" Foreground="White" FontWeight="Bold" FontSize="14"/>
                            <TextBlock x:Name="txtUserRole" Text="Технолог" Foreground="#BDC3C7" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки меню -->
                    <Button x:Name="btnDashboard" Content="🏠 Главная" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnProducts" Content="📦 Продукция" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnRecipes" Content="📋 Рецептуры" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnTechCards" Content="🗺️ Технологические карты" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnOrders" Content="📄 Заказы" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnBatches" Content="🏭 Партии" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnExtruder" Content="⚙️ Экструдер" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnMonitor" Content="📊 Мониторинг" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnDeviations" Content="⚠️ Отклонения" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnReports" Content="📈 Отчеты" Style="{StaticResource MenuButton}"/>

                    <Separator Background="#3D566E" Height="1" Margin="10,20"/>

                    <Button x:Name="btnLogout" Content="🚪 Выход" Style="{StaticResource MenuButton}" Foreground="#E53935"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#2E7D32">
                <Grid Margin="20,0">
                    <TextBlock x:Name="lblTitle" Text="Главная" 
                               FontSize="18" FontWeight="Bold" 
                               Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock x:Name="lblDateTime" Text="" 
                               Foreground="White" 
                               HorizontalAlignment="Right" 
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <ContentControl x:Name="ContentContainer" Grid.Row="1" Background="#F0F0F0"/>
        </Grid>
    </Grid>
</Window>