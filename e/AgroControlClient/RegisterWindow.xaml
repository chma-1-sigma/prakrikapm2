<Window x:Class="AgroControlClient.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АГРОКОНТРОЛЬ - Регистрация"
        Height="650" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#F0F0F0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="АГРОКОНТРОЛЬ" 
                           FontSize="28" FontWeight="Bold" 
                           Foreground="#2E7D32"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>

                <TextBlock Grid.Row="1" Text="Регистрация пользователя" 
                           FontSize="14" 
                           Foreground="#666"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <TextBlock Grid.Row="2" Text="Логин *" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtUsername" Grid.Row="3" Height="35" Margin="0,0,0,15"/>

                <TextBlock Grid.Row="4" Text="Пароль *" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" Grid.Row="5" Height="35" Margin="0,0,0,15"/>

                <TextBlock Grid.Row="6" Text="Подтверждение пароля *" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtConfirmPassword" Grid.Row="7" Height="35" Margin="0,0,0,15"/>

                <TextBlock Grid.Row="8" Text="ФИО *" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtFullName" Grid.Row="9" Height="35" Margin="0,0,0,15"/>

                <TextBlock Grid.Row="10" Text="Email *" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtEmail" Grid.Row="11" Height="35" Margin="0,0,0,15"/>

                <TextBlock Grid.Row="12" Text="Телефон" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtPhone" Grid.Row="13" Height="35" Margin="0,0,0,15"/>

                <TextBlock Grid.Row="14" Text="Подразделение" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbDepartment" Grid.Row="15" Height="35" Margin="0,0,0,20">
                    <ComboBoxItem Content="Технологический отдел" IsSelected="True"/>
                    <ComboBoxItem Content="Производственный цех"/>
                    <ComboBoxItem Content="Лаборатория"/>
                    <ComboBoxItem Content="IT-отдел"/>
                </ComboBox>

                <TextBlock Grid.Row="16" Text="Введите код с картинки *" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>

                <Grid Grid.Row="17" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image x:Name="imgCaptcha" Grid.Column="0" Width="260" Height="70" Stretch="Fill"/>
                    <Button x:Name="btnRefresh" Grid.Column="1" Content="⟳" Width="50" Height="50" Margin="10,0,0,0" FontSize="20" Background="#2196F3" Foreground="White"/>
                </Grid>

                <TextBox x:Name="txtCaptcha" Grid.Row="18" Height="35" Margin="0,0,0,25"/>

                <StackPanel Grid.Row="19" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="btnRegister" Content="Зарегистрироваться" Width="170" Height="40" Margin="0,0,15,0" Background="#2E7D32" Foreground="White" FontWeight="Bold"/>
                    <Button x:Name="btnBack" Content="Назад к входу" Width="140" Height="40" Background="#2196F3" Foreground="White" FontWeight="Bold"/>
                </StackPanel>

                <TextBlock x:Name="lblStatus" Grid.Row="20" Text="" 
                           Foreground="#E53935"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"
                           TextWrapping="Wrap"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>