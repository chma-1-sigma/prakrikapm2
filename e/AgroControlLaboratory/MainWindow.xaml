<Window x:Class="AgroControlLaboratory.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АГРОКОНТРОЛЬ - Лаборатория"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковое меню -->
        <Border Grid.Column="0" Background="#2C3E50">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="#1A252F" Height="70">
                        <TextBlock Text="АГРОКОНТРОЛЬ" 
                                   FontSize="18" FontWeight="Bold" 
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Border Background="#3D566E" Margin="0,10,0,10" Padding="15,10">
                        <StackPanel>
                            <TextBlock x:Name="txtUserName" Text="Васильева Елена Андреевна" Foreground="White" FontWeight="Bold" FontSize="14"/>
                            <TextBlock x:Name="txtUserRole" Text="Лаборант" Foreground="#BDC3C7" FontSize="12"/>
                            <TextBlock x:Name="txtUserDept" Text="Лаборатория контроля качества" Foreground="#BDC3C7" FontSize="11" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="btnDashboard" Content="🏠 Главная" Height="45" Background="Transparent" Foreground="White" FontSize="13" HorizontalAlignment="Stretch" Cursor="Hand"/>
                    <Button x:Name="btnRawMaterials" Content="📦 Сырье" Height="45" Background="Transparent" Foreground="White" FontSize="13" HorizontalAlignment="Stretch" Cursor="Hand"/>
                    <Button x:Name="btnFinishedGoods" Content="🏭 Готовая продукция" Height="45" Background="Transparent" Foreground="White" FontSize="13" HorizontalAlignment="Stretch" Cursor="Hand"/>
                    <Button x:Name="btnHistory" Content="📋 История испытаний" Height="45" Background="Transparent" Foreground="White" FontSize="13" HorizontalAlignment="Stretch" Cursor="Hand"/>
                    <Button x:Name="btnReports" Content="📊 Отчеты" Height="45" Background="Transparent" Foreground="White" FontSize="13" HorizontalAlignment="Stretch" Cursor="Hand"/>

                    <Separator Background="#3D566E" Height="1" Margin="10,20"/>

                    <Button x:Name="btnLogout" Content="🚪 Выход" Height="45" Background="Transparent" Foreground="#E53935" FontSize="13" HorizontalAlignment="Stretch" Cursor="Hand"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#7B1FA2">
                <Grid Margin="20,0">
                    <TextBlock x:Name="lblTitle" Text="Главная" 
                               FontSize="18" FontWeight="Bold" 
                               Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock x:Name="lblDateTime" Text="" 
                               Foreground="White" 
                               HorizontalAlignment="Right" 
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <ContentControl x:Name="ContentContainer" Grid.Row="1" Background="#F0F0F0"/>
        </Grid>
    </Grid>
</Window>