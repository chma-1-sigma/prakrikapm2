<Window x:Class="AgroControlLaboratory.Views.QualityTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔬 Лабораторное испытание"
        Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Background="#F0F0F0">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="🔬 Лабораторное испытание" 
                       FontSize="22" FontWeight="Bold" 
                       Foreground="#7B1FA2"
                       Margin="0,0,0,20"/>

            <!-- Информация о партии (без CardStyle) -->
            <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Партия:" FontWeight="Bold"/>
                        <TextBlock Text="Продукт:" FontWeight="Bold" Margin="0,10,0,0"/>
                        <TextBlock Text="Тип:" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="txtBatchNumber" Text=""/>
                        <TextBlock x:Name="txtProductName" Text="" Margin="0,10,0,0"/>
                        <TextBlock x:Name="txtSampleType" Text="" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Grid.Row="2" Text="Параметры контроля" 
                       FontSize="16" FontWeight="Bold" 
                       Margin="0,0,0,10"/>

            <DataGrid x:Name="dgParameters" Grid.Row="3" Height="250" Margin="0,0,0,15" AutoGenerateColumns="False" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Параметр" Binding="{Binding ParameterName}" Width="150"/>
                    <DataGridTextColumn Header="Норма" Binding="{Binding StandardValue}" Width="100"/>
                    <DataGridTextColumn Header="Ед.изм" Binding="{Binding Unit}" Width="80"/>
                    <DataGridTextColumn Header="Факт" Binding="{Binding MeasuredValue}" Width="120"/>
                    <DataGridTextColumn Header="Результат" Binding="{Binding Result}" Width="100"/>
                    <DataGridTextColumn Header="Обязат." Binding="{Binding IsMandatory}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Grid.Row="4" Text="Комментарий" 
                       FontSize="14" FontWeight="SemiBold" 
                       Margin="0,0,0,5"/>
            <TextBox x:Name="txtComment" Grid.Row="5" Height="60" 
                     TextWrapping="Wrap" AcceptsReturn="True"
                     Margin="0,0,0,15"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnSave" Content="💾 Сохранить результаты" Background="#7B1FA2" Foreground="White" FontSize="13" FontWeight="SemiBold" Height="35" Padding="15,0" Margin="0,0,15,0" Cursor="Hand"/>
                <Button x:Name="btnApprove" Content="✅ Одобрить" Background="#4CAF50" Foreground="White" FontSize="13" Height="35" Padding="15,0" Margin="0,0,15,0" Cursor="Hand"/>
                <Button x:Name="btnBlock" Content="❌ Заблокировать" Background="#F44336" Foreground="White" FontSize="13" Height="35" Padding="15,0" Margin="0,0,15,0" Cursor="Hand"/>
                <Button x:Name="btnCancel" Content="Отмена" Background="#9E9E9E" Foreground="White" FontSize="13" Height="35" Padding="15,0" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>