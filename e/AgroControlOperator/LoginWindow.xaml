<Window x:Class="AgroControlOperator.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АГРОКОНТРОЛЬ - Аппаратчик"
        Height="480" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Grid Background="#F0F0F0">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="АГРОКОНТРОЛЬ" 
                       FontSize="28" FontWeight="Bold" 
                       Foreground="#1565C0"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,5"/>

            <TextBlock Grid.Row="1" Text="Модуль аппаратчика" 
                       FontSize="14" 
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <TextBlock Grid.Row="2" Text="Табельный номер" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtLogin" Grid.Row="3" Height="35" Margin="0,0,0,15" Text="operator.zavodov"/>

            <TextBlock Grid.Row="4" Text="Пароль" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtPassword" Grid.Row="5" Height="35" Margin="0,0,0,20" Password="123"/>

            <TextBlock Grid.Row="6" Text="Смена" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbShift" Grid.Row="7" Height="35" Margin="0,0,0,30" SelectedIndex="0">
                <ComboBoxItem Content="Утренняя смена (06:00 - 14:00)"/>
                <ComboBoxItem Content="Дневная смена (14:00 - 22:00)"/>
                <ComboBoxItem Content="Ночная смена (22:00 - 06:00)"/>
            </ComboBox>

            <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,53,0,-54">
                <Button x:Name="btnLogin" Content="Войти" Width="120" Height="40" Margin="0,0,15,0" Background="#1565C0" Foreground="White" FontWeight="Bold"/>
                <Button x:Name="btnCancel" Content="Отмена" Width="120" Height="40" Background="#E53935" Foreground="White" FontWeight="Bold"/>
            </StackPanel>

            <TextBlock x:Name="lblStatus" Grid.Row="9" Text="" 
                       Foreground="#E53935"
                       HorizontalAlignment="Center"
                       Margin="0,15,0,0"/>
        </Grid>
    </Grid>
</Window>