<Window x:Class="AgroControlOperator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АГРОКОНТРОЛЬ - Аппаратчик"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковое меню -->
        <Border Grid.Column="0" Background="#1A237E">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Логотип с картинкой -->
                    <Border Background="#0D1B5E" Height="80">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image x:Name="LogoImage" Width="40" Height="40" Margin="0,0,10,0" Stretch="Uniform"/>
                            <TextBlock Text="АГРОКОНТРОЛЬ" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#283593" Margin="0,10,0,10" Padding="15,10">
                        <StackPanel>
                            <TextBlock x:Name="txtUserName" Text="Заводов Сергей Николаевич" Foreground="White" FontWeight="Bold" FontSize="14"/>
                            <TextBlock x:Name="txtUserRole" Text="Аппаратчик" Foreground="#BDC3C7" FontSize="12"/>
                            <TextBlock x:Name="txtUserShift" Text="Смена: Утренняя" Foreground="#BDC3C7" FontSize="11" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="btnActiveBatches" Content="▶ Активные партии" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnProgram" Content="📋 Программа партии" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnExtruder" Content="⚙️ Экструдер LIVE" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnJournal" Content="📄 Журнал партии" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnProblem" Content="⚠️ Сообщить о проблеме" Style="{StaticResource MenuButton}"/>

                    <Separator Background="#283593" Height="1" Margin="10,20"/>

                    <Button x:Name="btnLogout" Content="🚪 Выход" Style="{StaticResource MenuButton}" Foreground="#E53935"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1565C0">
                <Grid Margin="20,0">
                    <TextBlock x:Name="lblTitle" Text="Активные партии" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock x:Name="lblDateTime" Text="" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <ContentControl x:Name="ContentContainer" Grid.Row="1" Background="#F0F0F0"/>
        </Grid>
    </Grid>
</Window>