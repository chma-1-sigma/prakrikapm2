<Window x:Class="AgroControlLaboratory.Views.QualityTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔬 Лабораторное испытание"
        Height="650" Width="800"
        MinHeight="500" MinWidth="600"
        MaxHeight="1000" MaxWidth="1200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F8F9FA">

    <Grid>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <Border Width="48" Height="48" 
                        Background="#F3E5F5" 
                        CornerRadius="12" Margin="0,0,14,0">
                    <TextBlock Text="🔬" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Лабораторное испытание" 
                               FontSize="22" FontWeight="Bold" 
                               Foreground="#212529"/>
                    <TextBlock Text="Контроль качества продукции" 
                               FontSize="13" Foreground="#6C757D"/>
                </StackPanel>
            </StackPanel>

            <!-- Информация о партии -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Партия" FontSize="11" Foreground="#6C757D" Margin="0,0,0,4"/>
                        <TextBlock x:Name="txtBatchNumber" Text="" FontSize="16" FontWeight="SemiBold" Foreground="#212529"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Продукт" FontSize="11" Foreground="#6C757D" Margin="0,0,0,4"/>
                        <TextBlock x:Name="txtProductName" Text="" FontSize="16" FontWeight="SemiBold" Foreground="#212529"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Тип образца" FontSize="11" Foreground="#6C757D" Margin="0,0,0,4"/>
                        <TextBlock x:Name="txtSampleType" Text="" FontSize="16" FontWeight="SemiBold" Foreground="#212529"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Grid.Row="2" Text="Параметры контроля" 
                       FontSize="16" FontWeight="Bold" 
                       Foreground="#212529"
                       Margin="0,0,0,12"/>

            <Border Grid.Row="3" Background="White" 
                    BorderBrush="#DEE2E6" BorderThickness="1" 
                    CornerRadius="10" Margin="0,0,0,18">
                <DataGrid x:Name="dgParameters" Height="280" 
                          AutoGenerateColumns="False" 
                          Background="Transparent"
                          BorderThickness="0"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Параметр" Binding="{Binding ParameterName}" Width="160"/>
                        <DataGridTextColumn Header="Норма" Binding="{Binding StandardValue}" Width="100"/>
                        <DataGridTextColumn Header="Ед.изм" Binding="{Binding Unit}" Width="80"/>
                        <DataGridTextColumn Header="Факт" Binding="{Binding MeasuredValue}" Width="120"/>
                        <DataGridTextColumn Header="Результат" Binding="{Binding Result}" Width="120"/>
                        <DataGridTextColumn Header="Обязат." Binding="{Binding IsMandatory}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <TextBlock Grid.Row="4" Text="Комментарий" 
                       FontSize="14" FontWeight="SemiBold" 
                       Foreground="#495057"
                       Margin="0,0,0,8"/>
            <TextBox x:Name="txtComment" Grid.Row="5" Height="70" 
                     TextWrapping="Wrap" AcceptsReturn="True"
                     Margin="0,0,0,20"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnSave" Content="💾 Сохранить результаты" 
                        Style="{StaticResource PrimaryButton}" Margin="0,0,12,0"/>
                <Button x:Name="btnApprove" Content="✅ Одобрить" 
                        Style="{StaticResource SuccessButton}" Margin="0,0,12,0"/>
                <Button x:Name="btnBlock" Content="❌ Заблокировать" 
                        Style="{StaticResource DangerButton}" Margin="0,0,12,0"/>
                <Button x:Name="btnCancel" Content="Отмена" 
                        Background="#E9ECEF" Foreground="#495057"
                        Style="{StaticResource SecondaryButton}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>