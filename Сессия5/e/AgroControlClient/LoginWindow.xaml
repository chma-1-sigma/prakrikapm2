<Window x:Class="AgroControlClient.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АГРОКОНТРОЛЬ — Аппаратчик"
        Height="560" Width="480"
        MinHeight="500" MinWidth="400"
        MaxHeight="800" MaxWidth="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#F8F9FA">

    <Grid>
        <!-- Фоновый градиент сверху -->
        <Border Height="200" VerticalAlignment="Top">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#2E7D32" Offset="0"/>
                    <GradientStop Color="#1B5E20" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Основная карточка -->
        <Border Background="White" 
                CornerRadius="16" 
                Margin="30,60,30,30"
                Padding="35,30"
                VerticalAlignment="Top">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.15"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Иконка/логотип -->
                <Border Grid.Row="0" Width="70" Height="70" 
                        Background="#E8F5E9" 
                        CornerRadius="16" 
                        HorizontalAlignment="Center"
                        Margin="0,0,0,15">
                    <TextBlock Text="🌿" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Grid.Row="1" Text="АГРОКОНТРОЛЬ" 
                           FontSize="26" FontWeight="Bold" 
                           Foreground="#212529"
                           HorizontalAlignment="Center"/>

                <TextBlock Grid.Row="2" Text="Модуль технолога" 
                           FontSize="14" 
                           Foreground="#6C757D"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,30"/>

                <!-- Логин -->
                <TextBlock Grid.Row="3" Text="Логин" FontSize="13" FontWeight="SemiBold" 
                           Foreground="#495057" Margin="0,0,0,6"/>
                <TextBox x:Name="txtLogin" Grid.Row="4" 
                         Text="admin" Margin="0,0,0,16"/>

                <!-- Пароль -->
                <TextBlock Grid.Row="5" Text="Пароль" FontSize="13" FontWeight="SemiBold" 
                           Foreground="#495057" Margin="0,0,0,6"/>
                <PasswordBox x:Name="txtPassword" Grid.Row="6" 
                             Password="123" Margin="0,0,0,16"/>

                <!-- Капча -->
                <TextBlock Grid.Row="7" Text="Код с картинки" FontSize="13" FontWeight="SemiBold" 
                           Foreground="#495057" Margin="0,0,0,6"/>

                <Grid Grid.Row="8" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#F8F9FA" 
                            BorderBrush="#DEE2E6" BorderThickness="1.5" 
                            CornerRadius="6" Height="80">
                        <Image x:Name="imgCaptcha" Stretch="Uniform" Margin="5"/>
                    </Border>
                    <Button x:Name="btnRefresh" Grid.Column="1" 
                            Content="⟳" Width="48" Height="48" 
                            Margin="10,0,0,0" FontSize="20" 
                            Background="#E9ECEF" Foreground="#495057"
                            BorderThickness="0" Cursor="Hand"/>
                </Grid>

                <TextBox x:Name="txtCaptcha" Grid.Row="9" Margin="0,0,0,25"/>

                <!-- Кнопки -->
                <StackPanel Grid.Row="10" Orientation="Vertical" HorizontalAlignment="Stretch">
                    <Button x:Name="btnLogin" Content="Войти в систему" 
                            Height="45" FontSize="15" FontWeight="SemiBold"
                            Background="#2E7D32" Foreground="White"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="6" Height="{TemplateBinding Height}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                        <Button x:Name="btnRegister" Content="Регистрация" 
                                Width="130" Height="38" Margin="0,0,10,0"
                                Background="Transparent" Foreground="#2E7D32"
                                BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
                        <Button x:Name="btnCancel" Content="Отмена" 
                                Width="130" Height="38"
                                Background="Transparent" Foreground="#DC3545"
                                BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock x:Name="lblStatus" Grid.Row="10" Text="" 
                           Foreground="#DC3545"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,5"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>
    </Window>