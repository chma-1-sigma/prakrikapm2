<Window x:Class="AgroControlClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АГРОКОНТРОЛЬ — Модуль технолога"
        Height="750" Width="1350"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        Background="#F8F9FA">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== БОКОВОЕ МЕНЮ ========== -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Шапка с логотипом -->
                    <Border Background="{StaticResource SidebarHeaderBg}" Height="90" Padding="20,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="44" Height="44" 
                                    Background="{StaticResource AccentColor}" 
                                    CornerRadius="10" Margin="0,0,14,0">
                                <TextBlock Text="🌿" FontSize="22" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="АГРОКОНТРОЛЬ" 
                                           FontSize="15" FontWeight="Bold" 
                                           Foreground="White"/>
                                <TextBlock Text="Модуль технолога" 
                                           FontSize="11" 
                                           Foreground="#ADB5BD"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Инфо о пользователе -->
                    <Border Background="{StaticResource SidebarHover}" 
                            Margin="16,16,16,10" 
                            Padding="16,14" 
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock x:Name="txtUserName" 
                                       Text="Иванов Иван Петрович" 
                                       Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock x:Name="txtUserRole" 
                                       Text="Технолог" 
                                       Foreground="#ADB5BD" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="ОСНОВНОЕ МЕНЮ" 
                               FontSize="10" FontWeight="Bold" 
                               Foreground="#6C757D" 
                               Margin="24,16,0,8"/>

                    <!-- Кнопки меню -->
                    <Button x:Name="btnDashboard" Content="🏠  Главная" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnProducts" Content="📦  Продукция" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnRecipes" Content="📋  Рецептуры" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnTechCards" Content="🗺️  Технологические карты" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnOrders" Content="📄  Заказы" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnBatches" Content="🏭  Партии" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnExtruder" Content="⚙️  Экструдер" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnMonitor" Content="📊  Мониторинг" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnDeviations" Content="⚠️  Отклонения" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnReports" Content="📈  Отчеты" Style="{StaticResource MenuButton}"/>

                    <Separator Background="#343A40" Margin="20,20"/>

                    <Button x:Name="btnLogout" Content="🚪  Выход" 
                            Style="{StaticResource MenuButton}" 
                            Foreground="#DC3545"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ========== ОСНОВНАЯ ОБЛАСТЬ ========== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Верхняя панель -->
            <Border Grid.Row="0" Background="White" 
                    BorderBrush="#DEE2E6" BorderThickness="0,0,0,1">
                <Grid Margin="28,0">
                    <TextBlock x:Name="lblTitle" Text="Главная" 
                               FontSize="20" FontWeight="Bold" 
                               Foreground="#212529" 
                               VerticalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Right" 
                                VerticalAlignment="Center">
                        <Border Background="#E8F5E9" 
                                CornerRadius="20" 
                                Padding="12,6" 
                                Margin="0,0,12,0">
                            <TextBlock Text="🟢  Система работает" 
                                       FontSize="12" 
                                       Foreground="#2E7D32"/>
                        </Border>
                        <TextBlock x:Name="lblDateTime" Text="" 
                                   FontSize="13" 
                                   Foreground="#6C757D" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl x:Name="ContentContainer" Grid.Row="1" 
                            Background="{StaticResource ContentBg}"/>
        </Grid>
    </Grid>
    </Window>