<Window x:Class="AgroControlClient.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АГРОКОНТРОЛЬ — Регистрация"
        Height="720" Width="520"
        MinHeight="650" MinWidth="450"
        MaxHeight="900" MaxWidth="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#F8F9FA">
    <Grid>
        <Border Height="180" VerticalAlignment="Top">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#2E7D32" Offset="0"/>
                    <GradientStop Color="#1B5E20" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Border Background="White" 
                CornerRadius="16" 
                Margin="30,40,30,20"
                Padding="35,25">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.15"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Width="60" Height="60" 
                            Background="#E8F5E9" CornerRadius="12" 
                            HorizontalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock Text="📝" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Grid.Row="1" Text="Регистрация" 
                               FontSize="24" FontWeight="Bold" 
                               Foreground="#212529"
                               HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="2" Text="Создайте новую учетную запись" 
                               FontSize="13" 
                               Foreground="#6C757D"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,25"/>

                    <!-- Логин -->
                    <TextBlock Grid.Row="3" Text="Логин *" FontSize="13" FontWeight="SemiBold" 
                               Foreground="#495057" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtUsername" Grid.Row="4" Margin="0,0,0,14"/>

                    <!-- Пароль -->
                    <TextBlock Grid.Row="5" Text="Пароль *" FontSize="13" FontWeight="SemiBold" 
                               Foreground="#495057" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="txtPassword" Grid.Row="6" Margin="0,0,0,14"/>

                    <!-- Подтверждение -->
                    <TextBlock Grid.Row="7" Text="Подтверждение пароля *" FontSize="13" FontWeight="SemiBold" 
                               Foreground="#495057" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="txtConfirmPassword" Grid.Row="8" Margin="0,0,0,14"/>

                    <!-- ФИО -->
                    <TextBlock Grid.Row="9" Text="ФИО *" FontSize="13" FontWeight="SemiBold" 
                               Foreground="#495057" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtFullName" Grid.Row="10" Margin="0,0,0,14"/>

                    <!-- Email -->
                    <TextBlock Grid.Row="11" Text="Email *" FontSize="13" FontWeight="SemiBold" 
                               Foreground="#495057" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtEmail" Grid.Row="12" Margin="0,0,0,14"/>

                    <!-- Телефон -->
                    <TextBlock Grid.Row="13" Text="Телефон" FontSize="13" FontWeight="SemiBold" 
                               Foreground="#495057" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtPhone" Grid.Row="14" Margin="0,0,0,14"/>

                    <!-- Подразделение -->
                    <TextBlock Grid.Row="15" Text="Подразделение" FontSize="13" FontWeight="SemiBold" 
                               Foreground="#495057" Margin="0,0,0,6"/>
                    <ComboBox x:Name="cmbDepartment" Grid.Row="16" Margin="0,0,0,18">
                        <ComboBoxItem Content="Технологический отдел" IsSelected="True"/>
                        <ComboBoxItem Content="Производственный цех"/>
                        <ComboBoxItem Content="Лаборатория"/>
                        <ComboBoxItem Content="IT-отдел"/>
                    </ComboBox>

                    <!-- Капча -->
                    <TextBlock Grid.Row="17" Text="Код с картинки *" FontSize="13" FontWeight="SemiBold" 
                               Foreground="#495057" Margin="0,0,0,6"/>

                    <Grid Grid.Row="18" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#F8F9FA" 
                                BorderBrush="#DEE2E6" BorderThickness="1.5" 
                                CornerRadius="6" Height="70">
                            <Image x:Name="imgCaptcha" Stretch="Uniform" Margin="5"/>
                        </Border>
                        <Button x:Name="btnRefresh" Grid.Column="1" 
                                Content="⟳" Width="48" Height="48" 
                                Margin="10,0,0,0" FontSize="20" 
                                Background="#E9ECEF" Foreground="#495057"
                                BorderThickness="0" Cursor="Hand"/>
                    </Grid>

                    <TextBox x:Name="txtCaptcha" Grid.Row="19" Margin="0,0,0,22"/>

                    <!-- Кнопки -->
                    <StackPanel Grid.Row="20" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="btnRegister" Content="Зарегистрироваться" 
                                Width="180" Height="42" Margin="0,0,12,0"
                                Background="#2E7D32" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontWeight="SemiBold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="6" Height="{TemplateBinding Height}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="btnBack" Content="Назад" 
                                Width="140" Height="42"
                                Background="#17A2B8" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontWeight="SemiBold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="6" Height="{TemplateBinding Height}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <TextBlock x:Name="lblStatus" Grid.Row="20" Text="" 
                               Foreground="#DC3545"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Bottom"
                               Margin="0,0,0,5"
                               TextWrapping="Wrap"/>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
    </Window>